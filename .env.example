# consciousness-server — bare-metal environment template.
#
# Copy to .env (gitignored) and edit values. Loaded by your process
# manager (systemd EnvironmentFile, `env $(cat .env | xargs) node …`,
# or similar). core/server.js reads these via process.env at startup.
#
# Defaults shown match the in-code fallbacks; uncomment only the
# variables you need to override.
#
# For the Docker path, deploy/.env is auto-generated by
# bin/sync-ports from ports.yaml — this file is for users who run
# `node core/server.js` directly.

# =============================================================================
# Core — listener + storage roots
# =============================================================================

# Bind address for the HTTP/WebSocket listener.
# Used at: core/server.js:4002 (`process.env.CONSCIOUSNESS_HOST || '0.0.0.0'`).
# Set to 127.0.0.1 to restrict to loopback; 0.0.0.0 listens on all
# interfaces (default).
#CONSCIOUSNESS_HOST=0.0.0.0

# Listener port (canonical "what THIS process listens on").
# Used at: core/middleware/ports.js:100 — overrides ports.yaml and the
# hardcoded fallback (3032). Set this if you cannot edit ports.yaml or
# need a one-off override for this process.
#PORT=3032

# Alternate location for ports.yaml.
# Used at: core/middleware/ports.js:27. Leave unset to use the
# ports.yaml that ships in the repo root.
#CS_PORTS_FILE=/etc/consciousness/ports.yaml

# Directory containing agent role files (*.md).
# Used at: core/server.js:3695 (`process.env.AGENTS_DIR || "/opt/ecosystem/agents"`).
# For a bare-metal install run from the repo, the bundled roles live
# in ./agents.
AGENTS_DIR=./agents

# Directory containing skill definitions.
# Used at: core/server.js:3696 (`process.env.SKILLS_DIR || "/opt/ecosystem/skills"`).
# The bundled skills live in ./skills.
SKILLS_DIR=./skills

# =============================================================================
# Memory — Redis (required)
# =============================================================================
# Redis is a hard dependency. core/server.js:50–62 creates the client
# and connects unconditionally at startup; tasks, agent state, chat
# logs, and the agent bus all live in Redis.

# Redis host.
# Used at: core/server.js:52 (`process.env.REDIS_HOST || '127.0.0.1'`).
REDIS_HOST=127.0.0.1

# Redis port.
# Used at: core/server.js:53 (`process.env.REDIS_PORT || '6379'`).
REDIS_PORT=6379

# =============================================================================
# Semantic search — health probe + outbound gate
# =============================================================================

# Base URL for the semantic-search service. Probed by GET /health and
# proxied for query endpoints.
# Used at: core/server.js:624 and core/server.js:2569
# (`process.env.SEMANTIC_SEARCH_URL || 'http://localhost:3037'`).
SEMANTIC_SEARCH_URL=http://localhost:3037

# Comma-separated allowlist of hostnames the semantic-search URL may
# point at. Empty disables the allowlist (scheme validation only —
# the default that keeps single-machine setups working).
# Used at: core/server.js:593.
#SEMANTIC_SEARCH_ALLOWED_HOSTS=localhost,127.0.0.1

# Timeout (ms) for the semantic-search health probe.
# Used at: core/server.js:617 (`process.env.HEALTH_SEMANTIC_TIMEOUT_MS || '3000'`).
#HEALTH_SEMANTIC_TIMEOUT_MS=3000

# =============================================================================
# Ollama — optional embedding/model backend
# =============================================================================

# Ollama base URL. Used only by GET /api/ollama/tags.
# Used at: core/server.js:1478 (`process.env.OLLAMA_URL || 'http://localhost:11434'`).
#OLLAMA_URL=http://localhost:11434

# =============================================================================
# Auth — signed-request middleware (off | observe | enforce)
# =============================================================================
# All four variables are consumed by core/middleware/verify-signed.js.
# `off` (default) skips signature verification entirely; `observe`
# logs would-be rejections; `enforce` rejects unsigned/invalid
# requests. See docs/AUTH-MODE.md for the full state machine.

# Mode selector.
# Used at: core/middleware/verify-signed.js:31
# (`(process.env.AUTH_MODE || 'off').trim().toLowerCase()`).
#AUTH_MODE=off

# Base URL of the key-server used to fetch agent public keys.
# Used at: core/middleware/verify-signed.js:38
# (`process.env.KEY_SERVER_URL || 'http://key-server:3040'`).
# For a bare-metal install where key-server runs on the same host,
# use http://127.0.0.1:3040.
#KEY_SERVER_URL=http://127.0.0.1:3040

# Path to the observe-mode log (append-only JSONL of would-be
# rejections). Relative paths resolve against the process cwd.
# Used at: core/middleware/verify-signed.js:39.
#AUTH_OBSERVE_LOG=logs/auth-observe.log

# Verify-request timeout (ms) when calling the key-server.
# Used at: core/middleware/verify-signed.js:40.
#AUTH_VERIFY_TIMEOUT_MS=2000
