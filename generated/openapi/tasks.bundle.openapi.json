  "paths": {
    "/tasks": {
      "get": {
        "tags": [
          "tasks"
        ],
        "operationId": "listTasks",
        "summary": "List tasks",
        "description": "Results ordered by created_at DESC, ties broken by id.",
        "parameters": [
          {
            "name": "assigned_to",
            "in": "query",
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "description": "Return only tasks assigned to this agent.",
            "example": "CDX"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "PENDING",
                "IN_PROGRESS",
                "DONE",
                "FAILED",
                "CANCELLED"
              ]
            },
            "description": "Return only tasks in this status.",
            "example": "PENDING"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50
            },
            "description": "Maximum number of tasks to return."
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "description": "Number of matching tasks to skip before returning results."
          },
          {
            "name": "created_after",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Return tasks created strictly after this timestamp.",
            "example": "2026-05-09T23:24:57.451Z"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching tasks and pagination metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "total",
                    "pagination",
                    "tasks"
                  ],
                  "properties": {
                    "total": {
                      "type": "integer",
                      "minimum": 0,
                      "description": "Total number of tasks matching the filters."
                    },
                    "pagination": {
                      "type": "object",
                      "required": [
                        "limit",
                        "offset",
                        "returned"
                      ],
                      "properties": {
                        "limit": {
                          "type": "integer",
                          "minimum": 1
                        },
                        "offset": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "returned": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "next_offset": {
                          "type": "integer",
                          "minimum": 0,
                          "nullable": true
                        }
                      }
                    },
                    "tasks": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "id",
                          "project",
                          "assigned_to",
                          "created_by",
                          "title",
                          "description",
                          "priority",
                          "status",
                          "created_at"
                        ],
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "project": {
                            "type": "string"
                          },
                          "assigned_to": {
                            "type": "string"
                          },
                          "created_by": {
                            "type": "string"
                          },
                          "title": {
                            "type": "string"
                          },
                          "description": {
                            "type": "string"
                          },
                          "priority": {
                            "type": "string",
                            "enum": [
                              "URGENT",
                              "HIGH",
                              "NORMAL",
                              "LOW"
                            ]
                          },
                          "metadata": {
                            "type": "object",
                            "nullable": true,
                            "additionalProperties": true
                          },
                          "status": {
                            "type": "string",
                            "enum": [
                              "PENDING",
                              "IN_PROGRESS",
                              "DONE",
                              "FAILED",
                              "CANCELLED"
                            ]
                          },
                          "created_at": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "deadline": {
                            "type": "string",
                            "format": "date-time",
                            "nullable": true,
                            "description": "Target completion deadline. Optional; absence means no explicit due-by."
                          },
                          "claimed_at": {
                            "type": "string",
                            "format": "date-time",
                            "nullable": true
                          },
                          "started_at": {
                            "type": "string",
                            "format": "date-time",
                            "nullable": true
                          },
                          "completed_at": {
                            "type": "string",
                            "format": "date-time",
                            "nullable": true
                          },
                          "result": {
                            "type": "string",
                            "nullable": true
                          },
                          "artifacts_path": {
                            "type": "string",
                            "nullable": true,
                            "description": "Filesystem path to task artifacts or outputs (e.g. logs, generated files). Optional."
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Request validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "error"
                  ],
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "details": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      },
