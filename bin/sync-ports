#!/usr/bin/env bash
# sync-ports — generate deploy/.env from ports.yaml.
#
# Why: ports.yaml is the single source of truth for the port palette, and
# native servers consume it directly via lib/ports.{js,py}. But docker-
# compose can't parse YAML — it reads .env. This script translates one to
# the other so editing ports.yaml is enough to retune the whole stack.
#
# Output: writes/overwrites deploy/.env with PORT_<NAME>=<value> lines for
# every entry under the top-level `ports:` key in ports.yaml. Existing
# non-PORT_ lines in .env are preserved (user's AUTH_MODE, model picks,
# etc. survive).
#
# Usage:
#   bin/sync-ports            # write deploy/.env
#   bin/sync-ports --check    # exit 1 if .env is out of date with ports.yaml
#   bin/sync-ports --print    # dump generated lines to stdout, do not write

set -u

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PORTS_YAML="$REPO_ROOT/ports.yaml"
ENV_FILE="$REPO_ROOT/deploy/.env"

MODE="${1:-write}"
case "$MODE" in
  ""|write) MODE="write" ;;
  --check)  MODE="check" ;;
  --print)  MODE="print" ;;
  -h|--help)
    sed -n '2,18p' "$0" | sed 's/^# \?//'; exit 0 ;;
  *) echo "sync-ports: unknown arg: $1" >&2; exit 2 ;;
esac

if [ ! -f "$PORTS_YAML" ]; then
  echo "sync-ports: $PORTS_YAML not found" >&2
  exit 2
fi

# Awk extracts entries under the top-level `ports:` key. Format is fixed:
# top-level keys end with ":" and have no leading whitespace; nested keys
# have leading whitespace. Comments stripped before matching.
generated=$(awk '
  BEGIN { in_ports = 0 }
  {
    sub(/#.*$/, "")            # drop inline comments
    line = $0
  }
  /^[A-Za-z][A-Za-z0-9_-]*:[[:space:]]*$/ {
    name = $1; sub(/:$/, "", name)
    in_ports = (name == "ports")
    next
  }
  in_ports && /^[[:space:]]+[A-Za-z][A-Za-z0-9_-]*:[[:space:]]+[0-9]+/ {
    name = $1; sub(/:$/, "", name)
    port = $2
    upper = toupper(name); gsub(/-/, "_", upper)
    printf "PORT_%s=%s\n", upper, port
  }
' "$PORTS_YAML" | sort)

if [ -z "$generated" ]; then
  echo "sync-ports: no port entries found in $PORTS_YAML" >&2
  exit 1
fi

case "$MODE" in
  print)
    printf '%s\n' "$generated"
    exit 0 ;;
  check)
    if [ ! -f "$ENV_FILE" ]; then
      echo "sync-ports: $ENV_FILE missing — run bin/sync-ports to create" >&2
      exit 1
    fi
    current=$(grep -E '^PORT_[A-Z_]+=' "$ENV_FILE" | sort)
    if [ "$current" != "$generated" ]; then
      echo "sync-ports --check: $ENV_FILE drift from ports.yaml" >&2
      diff <(printf '%s\n' "$current") <(printf '%s\n' "$generated") || true
      exit 1
    fi
    echo "sync-ports --check: $ENV_FILE in sync"
    exit 0 ;;
esac

# write mode — preserve non-PORT_ user lines.
mkdir -p "$(dirname "$ENV_FILE")"
preserved=""
if [ -f "$ENV_FILE" ]; then
  preserved=$(grep -vE '^PORT_[A-Z_]+=' "$ENV_FILE" | sed '/^$/d' || true)
fi

{
  echo "# Auto-generated by bin/sync-ports from ports.yaml"
  echo "# Edit ports.yaml then re-run sync-ports — manual edits to PORT_* lines"
  echo "# WILL be overwritten. Non-PORT_ lines (AUTH_MODE, EMBED_MODEL, etc.)"
  echo "# are preserved."
  echo ""
  printf '%s\n' "$generated"
  if [ -n "$preserved" ]; then
    echo ""
    echo "# --- Preserved user settings ---"
    printf '%s\n' "$preserved"
  fi
} > "$ENV_FILE"

count=$(printf '%s\n' "$generated" | wc -l)
echo "sync-ports: wrote $count PORT_* lines to $ENV_FILE"
